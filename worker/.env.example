# ── 数据库 ────────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=showrunner
MYSQL_PASSWORD=change_this_password
MYSQL_DATABASE=showrunner

# ── Redis / BullMQ ────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── OpenAI-compatible Chat Completions（AI 分镜/文案解析）──
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://sub.sharellm.uk/v1
OPENAI_MODEL=gpt-5.5

# ── TTS 旁白 ──────────────────────────────────────────────
TTS_PROVIDER=kokoro
# OPENAI_TTS_API_KEY=sk-xxx
# OPENAI_TTS_BASE_URL=https://api.openai.com/v1
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=coral
# OPENAI_TTS_SPEED=0.95
# OPENAI_TTS_INSTRUCTIONS=Warm, clear product demo narration.

# ── Cloudflare R2 视频存储（可选）──────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── 视频目录 / 浏览器 ─────────────────────────────────────
VIDEO_DIR=/opt/showrunner/videos
WORKER_PORT=3001
WORKER_HOST=127.0.0.1
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
