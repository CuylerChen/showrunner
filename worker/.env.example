# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=showrunner
MYSQL_PASSWORD=change_this_password
MYSQL_DATABASE=showrunner

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI-compatible Chat Completions（AI 分镜/文案解析）
# 可使用任意兼容 Chat Completions 的接口
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# TTS 旁白
# 自建 Chat Completions gateway 没有 TTS 接口时保持 kokoro
TTS_PROVIDER=kokoro
# 如需远程高质量 TTS，改为 auto 或 openai 并配置以下变量
# OPENAI_TTS_API_KEY=sk-xxx
# OPENAI_TTS_BASE_URL=https://api.openai.com/v1
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=coral
# OPENAI_TTS_SPEED=0.95
# OPENAI_TTS_INSTRUCTIONS=Warm, clear product demo narration.
