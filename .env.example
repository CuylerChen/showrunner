# ── 数据库 ────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=showrunner
MYSQL_PASSWORD=change_this_password
MYSQL_DATABASE=showrunner

# ── JWT ───────────────────────────────────────────────────
# 生成方式: openssl rand -base64 32
JWT_SECRET=change_this_to_random_32_char_string

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── OpenAI-compatible Chat Completions（AI 解析）──────────
# 可使用任意兼容 Chat Completions 的接口
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── TTS 旁白 ──────────────────────────────────────────────
# 自建 Chat Completions gateway 没有 TTS 接口时保持 kokoro
TTS_PROVIDER=kokoro
# 如需远程高质量 TTS，改为 auto 或 openai 并配置以下变量
# OPENAI_TTS_API_KEY=sk-...
# OPENAI_TTS_BASE_URL=https://api.openai.com/v1
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=coral
# OPENAI_TTS_SPEED=0.95
# OPENAI_TTS_INSTRUCTIONS=Warm, clear product demo narration.

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://YOUR_VPS_IP

# ── Cloudflare R2 视频存储（可选，不配置则保存到服务器本地）──
# 前往 https://dash.cloudflare.com → R2 → 创建 Bucket → API 令牌
# R2_PUBLIC_URL：Bucket 公开访问地址（开启公共访问后获得，或绑定自定义域名）
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=showrunner-videos
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# ── Google OAuth（可选）──────────────────────────────────
# 前往 https://console.cloud.google.com → API 和服务 → 凭据 → 创建 OAuth 2.0 客户端 ID
# 授权重定向 URI 填写: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── GitHub OAuth（可选）──────────────────────────────────
# 前往 https://github.com/settings/developers → New OAuth App
# Authorization callback URL 填写: https://your-domain.com/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
