# ── 数据库（裸机部署默认使用系统级 MySQL）────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=showrunner
MYSQL_PASSWORD=change_this_password
MYSQL_DATABASE=showrunner

# ── JWT ───────────────────────────────────────────────────
# 生成方式: openssl rand -base64 32
JWT_SECRET=change_this_to_random_32_char_string

# ── Redis（裸机部署默认使用系统级 Redis）────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── OpenAI-compatible Chat Completions（AI 解析）──────────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://sub.sharellm.uk/v1
OPENAI_MODEL=gpt-5.5

# ── TTS 旁白 ──────────────────────────────────────────────
# 自建 Chat Completions gateway 没有 TTS 接口时保持 kokoro
TTS_PROVIDER=kokoro
# 如需远程高质量 TTS，改为 auto 或 openai 并配置以下变量
# OPENAI_TTS_API_KEY=sk-...
# OPENAI_TTS_BASE_URL=https://api.openai.com/v1
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=coral
# OPENAI_TTS_SPEED=0.95
# OPENAI_TTS_INSTRUCTIONS=Warm, clear product demo narration.

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
WORKER_INTERNAL_URL=http://127.0.0.1:3001
WORKER_PORT=3001
WORKER_HOST=127.0.0.1

# ── Paddle Billing 订阅支付 ───────────────────────────────
PADDLE_ENVIRONMENT=production
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
PADDLE_STARTER_PRICE_ID=
PADDLE_PRO_PRICE_ID=

# ── Cloudflare R2 视频存储（可选，不配置则保存到服务器本地）──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Google OAuth（可选）──────────────────────────────────
# 授权重定向 URI: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth（可选）──────────────────────────────────
# Authorization callback URL: https://your-domain.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── 视频目录 ──────────────────────────────────────────────
VIDEO_DIR=/opt/showrunner/videos
